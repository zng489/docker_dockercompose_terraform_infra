# ══════════════════════════════════════════════════════════════════════
# IMAGEM JUPYTER + PYSPARK
# ══════════════════════════════════════════════════════════════════════

# FROM python:3.11-slim-bookworm
#
# python → imagem oficial do Python mantida no Docker Hub.
#
# 3.11 → versão do Python. 3.11 é ~25% mais rápida que 3.10.
#   Compatível com PySpark 3.5, pandas 2.x, jupyterlab.
#
# slim → variante "enxuta" da imagem.
#   Remove: compiladores (gcc), man pages, documentação, testes.
#   Mantém: Python, pip, libs essenciais.
#   ~150MB vs ~900MB da imagem "full".
#
# bookworm → codinome do Debian 12 (lançado jun/2023).
#   Debian é preferido ao Alpine para Python porque:
#     - numpy, pandas, scipy usam código C compilado (extensões nativas)
#     - Alpine usa musl libc (não compatível com glibc)
#     - No Alpine: pip precisa COMPILAR essas libs do zero (~10-30 min)
#     - No Debian: pip baixa wheels pré-compilados (~10 segundos)
#     - Além disso, musl tem bugs sutis com threading e locale
FROM python:3.12-slim-bookworm

# apt-get update → atualiza o índice de pacotes disponíveis.
#   Sem isso, "apt-get install" pode falhar porque não sabe o que existe.
#
# apt-get install -y → instala pacotes sem pedir confirmação (-y = yes).
#
# --no-install-recommends → instala APENAS o pacote pedido.
#   Sem essa flag, apt também instala "recomendados" (sugestões).
#   Exemplo: instalar curl sem essa flag puxa ~50MB de extras.
#   Com a flag: apenas curl e suas dependências diretas.
#
# Pacotes:
#   curl    → para baixar o Spark (mesmo uso do Dockerfile do Spark)
#   tini    → init process (mesma justificativa)
#   procps  → ps, top, free (mesma justificativa)
#
# rm -rf /var/lib/apt/lists/*
#   Apaga o cache do apt (índice de pacotes).
#   Esse cache ocupa ~30MB e nunca mais será usado.
#   Sem essa limpeza, fica salvo permanentemente na layer da imagem.



# COPY --from=<imagem> → instrução de "multi-stage build".
#
# O que acontece nos bastidores:
#   1. Docker baixa eclipse-temurin:17-jre-alpine (imagem temporária)
#   2. Copia APENAS a pasta /opt/java dessa imagem para cá
#   3. Descarta todo o resto da imagem Alpine
#
# Por que isso é genial?
#   Alternativa tradicional: apt-get install openjdk-17-jre-headless
#     → Puxa ~300MB de dependências (fonts, X11, ca-certificates...)
#
#   Com COPY --from: copia ~180MB de Java limpo, sem dependências extras.
#     → Economia de ~120MB na imagem final.
#
# /opt/java/openjdk → é onde o Temurin instala o Java no Alpine.
# Copiamos para /opt/java aqui para manter o mesmo caminho.

RUN apt-get update && apt-get install -y --no-install-recommends \
    wget tini procps default-jre-headless \
    && rm -rf /var/lib/apt/lists/*



# JAVA_HOME → variável que MUITAS ferramentas Java consultam
#   para encontrar a instalação do Java.
#   PySpark, Hadoop client, e Maven usam JAVA_HOME.
#
# PATH → adiciona o diretório bin do Java ao PATH.
#   Permite rodar "java -version" em vez de "/opt/java/openjdk/bin/java -version".
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
ENV PATH="${JAVA_HOME}/bin:${PATH}"
# Por que instalar o Spark aqui se o processamento roda no cluster?
#
# O PySpark precisa dos JARs do Spark localmente porque:
#   1. O DRIVER roda aqui (Jupyter = Driver do Spark)
#   2. O Driver precisa dos JARs para:
#      - Criar o SparkSession (ponto de entrada da API)
#      - Serializar funções Python e enviar aos Workers
#      - Deserializar resultados que voltam dos Workers
#      - Carregar classes de configuração do Spark
#   3. Sem os JARs: "py4j.protocol.Py4JError: SparkContext not found"
#
# A versão do PySpark (pip) DEVE ser idêntica à versão do Spark (JARs).
# Se forem diferentes: erros de serialização e protocolo.
ENV SPARK_VERSION=3.5.8
ENV SPARK_HOME=/opt/spark
ENV PATH="${SPARK_HOME}/bin:${PATH}"

RUN wget https://dlcdn.apache.org/spark/spark-${SPARK_VERSION}/spark-${SPARK_VERSION}-bin-hadoop3.tgz \
    && tar xf spark-${SPARK_VERSION}-bin-hadoop3.tgz \
    && mv spark-${SPARK_VERSION}-bin-hadoop3 ${SPARK_HOME} \
    && rm spark-${SPARK_VERSION}-bin-hadoop3.tgz


# pip install → instala pacotes Python do PyPI (Python Package Index).
#
# --no-cache-dir → NÃO salva os pacotes .whl baixados no cache do pip.
#   O cache fica em ~/.cache/pip/ e pode ter 50-200MB.
#   Dentro de uma imagem Docker, esse cache é desperdício puro
#   (nunca mais será reusado).
#
# Pacotes:
#   jupyterlab → evolução do Jupyter Notebook.
#     Interface web moderna com file browser, terminal, extensões.
#     É o padrão da comunidade desde 2023 (Notebook clássico está em manutenção).
#
#   pyspark==${SPARK_VERSION} → API Python para Apache Spark.
#     O == garante que a versão do pip SEJA EXATA à versão dos JARs.
#     Se instalar pyspark==3.4 com JARs do 3.5 → erros de protocolo.
#
#   delta-spark==3.1.0 → biblioteca Delta Lake para Spark.
#     Delta Lake adiciona ao Spark:
#       - Transações ACID (atomicidade, consistência)
#       - Time Travel (consultar dados de ontem, semana passada)
#       - Schema enforcement (rejeita dados com schema errado)
#       - MERGE (upsert: insert + update em uma operação)
#     3.1.0 é compatível com Spark 3.5.x.
#
#   pandas → biblioteca de manipulação de dados em memória.
#     Complementa PySpark para datasets pequenos.
#     PySpark pode converter DataFrame Spark ↔ DataFrame Pandas.
#
#   matplotlib → biblioteca de visualização (gráficos).
#     Permite criar plots diretamente nos notebooks.
RUN pip install --no-cache-dir \
    jupyterlab pyspark==${SPARK_VERSION} delta-spark==3.2.1 pandas matplotlib

# useradd → cria um novo usuário no sistema Linux.
#
# -m → cria o diretório home (/home/jovyan).
#   Sem -m, o usuário existe mas não tem pasta home.
#   Jupyter precisa de home para salvar configs e arquivos.
#
# -s /bin/bash → define bash como shell padrão do usuário.
#   Útil quando fizer "docker exec -it jupyter bash".
#
# jovyan → nome de usuário. É convenção da comunidade Jupyter.
#   Origem: "jovian" (relativo a Júpiter) → "jovyan" (estilizado).
#   Todas as imagens oficiais do Jupyter usam esse nome.
#   Não tem significado técnico; é apenas convenção.
#
# USER jovyan → a partir daqui, TUDO roda como "jovyan" (não root).
#   - As instruções RUN seguintes executam como jovyan
#   - O CMD/ENTRYPOINT roda como jovyan
#   - Arquivos criados pertencem a jovyan
#
#   Por que NÃO rodar como root?
#     1. Segurança: se alguém explorar uma vulnerabilidade do Jupyter,
#        terá acesso apenas como jovyan (limitado), não como root (total).
#     2. Prática: evita criar arquivos como root nos volumes montados,
#        que depois você não consegue editar no host sem sudo.
RUN useradd -m -s /bin/bash jovyan
USER jovyan

# WORKDIR → define /home/jovyan como diretório padrão.
#   Quando o Jupyter abrir, mostra este diretório.
#   Notebooks criados ficam salvos aqui (ou em subdiretórios).
WORKDIR /home/jovyan

ENTRYPOINT ["tini", "--"]

# CMD → comando padrão que roda quando o container inicia.
#
# Diferença entre ENTRYPOINT e CMD:
#   ENTRYPOINT = sempre executa (tini --)
#   CMD = argumento padrão do ENTRYPOINT (pode ser sobrescrito)
#
#   Neste caso, o container executa:
#     tini -- jupyter lab --ip=0.0.0.0 --port=8888 ...
#
# Formato ["array", "json"] (exec form):
#   Executa o comando DIRETAMENTE (sem shell intermediário).
#   Sinais Unix chegam direto no processo.
#   Se usasse string "jupyter lab ..." (shell form),
#   Docker rodaria: /bin/sh -c "jupyter lab ..."
#   e sinais iriam para o sh, não para o jupyter.
#
# Argumentos:
#   --ip=0.0.0.0 → aceita conexões de QUALQUER IP.
#     Por padrão, Jupyter aceita apenas localhost (127.0.0.1).
#     Dentro do Docker, "localhost" é o container em si.
#     Para acessar do host (seu browser), precisa aceitar 0.0.0.0.
#
#   --port=8888 → porta onde o Jupyter escuta (padrão da comunidade).
#
#   --no-browser → NÃO tenta abrir um browser ao iniciar.
#     Dentro do container não existe browser.
#     Sem essa flag, o Jupyter mostra um warning inútil no log.
#
#   --NotebookApp.token=spark123 → token de autenticação.
#     Qualquer pessoa com acesso à porta 8888 precisa desse token.
#     É uma proteção básica para ambientes de desenvolvimento.
#     ⚠️ Em produção: use JupyterHub com OAuth/LDAP, não token fixo.
CMD ["jupyter", "lab", "--ip=0.0.0.0", "--port=8888", "--no-browser", "--NotebookApp.token=spark123"]